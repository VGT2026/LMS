# Server Configuration
PORT=3001
NODE_ENV=development

# Database — use DATABASE_URL on Railway, or individual vars locally
# DATABASE_URL=mysql://user:password@host:3306/lms_database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lms_database
DB_USER=root
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Bootstrap platform superadmin (created on migrate + server start if missing)
SUPERADMIN_EMAIL=superadmin@lmspro.com
SUPERADMIN_PASSWORD=SuperAdmin123!
SUPERADMIN_NAME=Platform Superadmin
SUPERADMIN_CREATE_ADMIN_MAX=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS — comma-separated browser origins (Vercel + local Vite)
# Production (Railway):
# CORS_ORIGINS=https://lms-frontend-two-lilac.vercel.app,http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://localhost:8081

# Frontend URL (password reset links)
FRONTEND_URL=http://localhost:8080

# SMTP (optional — instructor welcome / password reset email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APP_NAME=LMS Pro

# Firebase Admin (POST /api/auth/firebase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# OpenAI (optional — /api/ai/* routes)
OPENAI_API_KEY=
